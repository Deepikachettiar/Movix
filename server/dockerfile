FROM node:22-alpine

# Explicitly declare a production execution lifecycle
ENV NODE_ENV=production
WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev && chown -R node:node /app

# Ensure that copied application code is owned by the node user
COPY --chown=node:node . .

# Drop privileges down to the built-in, unprivileged 'node' user
USER node

EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=3s \
  CMD node -e "fetch('http://localhost:3000/').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

# Execute server (Adjust index.js if your main application file is server.js or app.js)
CMD ["node", "server.js"]