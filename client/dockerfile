FROM node:20-alpine AS builder
WORKDIR /app

# Vite bakes VITE_ env vars into the bundle at build time,
# so they must be available as build args
ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/original
ARG VITE_CURRENCY=₹
ARG VITE_API_URL=http://localhost:5000
ARG VITE_BASE_URL=http://localhost:3000

ENV VITE_CLERK_PUBLISHABLE_KEY=$VITE_CLERK_PUBLISHABLE_KEY
ENV VITE_TMDB_IMAGE_BASE_URL=$VITE_TMDB_IMAGE_BASE_URL
ENV VITE_CURRENCY=$VITE_CURRENCY
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_BASE_URL=$VITE_BASE_URL

COPY package*.json ./

RUN npm install

COPY . .

RUN npm run build

USER node

# Stage 2: Web Server Layer (non-root)
FROM nginxinc/nginx-unprivileged:1.25-alpine

# Copy our custom routing profile 
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy compiled files from stage 1 (Use /app/dist if your app utilizes Vite, or /app/build if it uses Create-React-App)
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s \
  CMD wget --quiet --tries=1 --spider http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]